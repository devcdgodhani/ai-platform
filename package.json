{
  "name": "ai-platform",
  "version": "0.0.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma"
    ]
  },
  "private": true,
  "description": "Enterprise AI Platform Monorepo",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @ai-platform/api build",
    "build:web": "pnpm --filter @ai-platform/web build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @ai-platform/api test:e2e",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @ai-platform/api db:migrate",
    "db:generate": "pnpm --filter @ai-platform/api db:generate",
    "db:seed": "pnpm --filter @ai-platform/api db:seed",
    "db:studio": "pnpm --filter @ai-platform/api db:studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  }
}