# ─────────────────────────────────────────────────────────
# Database — pgvector/pgvector:pg16 (Postgres + vector ext)
# ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/aiplatform?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aiplatform

# ─────────────────────────────────────────────────────────
# Redis (Cache + BullMQ broker)
# Docker maps host:6380 → container:6379 to avoid conflicts with local Redis
# ─────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
JWT_EXPIRY="15m"
REFRESH_TOKEN_SECRET="change-me-to-another-long-random-string"
REFRESH_TOKEN_EXPIRY="7d"

# ─────────────────────────────────────────────────────────
# AI Providers
# ─────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
DEFAULT_AI_PROVIDER="openai"
DEFAULT_MODEL="gpt-4o"
DEFAULT_EMBEDDING_MODEL="text-embedding-3-small"
DEFAULT_EMBEDDING_DIMENSIONS=1536

# ─────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT=3000
API_VERSION="v1"
API_PREFIX="api"
CORS_ORIGINS="http://localhost:5173"

# ─────────────────────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────────────────────
VITE_API_URL="http://localhost:3000/api/v1"
VITE_SOCKET_URL="http://localhost:3000"
VITE_APP_NAME="AI Platform"

# ─────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ─────────────────────────────────────────────────────────
# Logging & Observability
# ─────────────────────────────────────────────────────────
LOG_LEVEL="info"
SENTRY_DSN=""

# ─────────────────────────────────────────────────────────
# File Storage
# ─────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=50
